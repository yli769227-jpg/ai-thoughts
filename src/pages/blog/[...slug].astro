---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeBlock from '../../components/SubscribeBlock.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);

const all = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const idx = all.findIndex((p) => p.id === post.id);
const total = all.length;
const num = String(total - idx).padStart(2, '0');
const next = all[idx + 1];
const prev = all[idx - 1];

const date = post.data.pubDate.toISOString().slice(0, 10);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title={post.data.title} description={post.data.description}>
	<main class="container">
		<article class="article">
			<a class="back" href={base + '/blog/'}>← back to index</a>
			<div class="a-date">{date} · #{num}</div>
			<h1>{post.data.title}</h1>
			<p class="a-lead">{post.data.description}</p>
			<hr class="sep" />
			<div class="prose" data-reveal-children>
				<Content />
			</div>
			<SubscribeBlock />
			<hr class="sep" />
			<div class="nav">
				<a class="back-bottom" href={base + '/blog/'}>← index</a>
				<span class="next-wrap">
					{prev && (
						<span class="nav-item">
							← prev <a href={`${base}/blog/${prev.id}/`}>{prev.data.title}</a>
						</span>
					)}
					{next && (
						<span class="nav-item">
							next → <a href={`${base}/blog/${next.id}/`}>{next.data.title}</a>
						</span>
					)}
				</span>
			</div>
		</article>
	</main>
</BaseLayout>

<style>
	.article {
		padding-top: 2em;
		max-width: 720px;
		margin: 0 auto;
		animation: enter 0.6s cubic-bezier(0.23, 1, 0.32, 1);
	}
	@keyframes enter {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: none;
		}
	}
	.back,
	.back-bottom {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		font-family: var(--font-mono);
		font-size: 0.82em;
		color: var(--slate);
		text-decoration: none;
		margin: 1em 0 2em;
	}
	.back:hover,
	.back-bottom:hover {
		color: var(--accent);
	}
	.a-date {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--accent);
		letter-spacing: 0.18em;
		text-transform: uppercase;
		margin-bottom: 0.8em;
	}
	.article h1 {
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 3.6em;
		line-height: 1.05;
		letter-spacing: -0.015em;
		color: var(--ink);
		margin: 0 0 0.35em;
	}
	.a-lead {
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.35em;
		color: var(--ink);
		line-height: 1.45;
		margin: 0 0 2em;
	}
	.sep {
		border: none;
		height: 1px;
		background: var(--silver);
		margin: 2em 0 2.5em;
	}
	.prose {
		font-size: 1.05em;
		line-height: 1.85;
		color: #2a3150;
	}
	.prose :global(p) {
		margin: 0 0 1.4em;
	}
	.prose :global(h2) {
		font-family: var(--font-display);
		font-size: 1.9em;
		font-weight: 400;
		color: var(--ink);
		margin: 2em 0 0.5em;
		letter-spacing: -0.01em;
	}
	.prose :global(h3) {
		font-family: var(--font-display);
		font-size: 1.4em;
		font-weight: 400;
		color: var(--ink);
		margin: 1.6em 0 0.4em;
	}
	.prose :global(strong) {
		font-weight: 600;
		color: var(--ink);
		background: linear-gradient(transparent 62%, rgba(41, 72, 255, 0.18) 62%);
	}
	.prose :global(blockquote) {
		border-left: 3px solid var(--accent);
		padding: 0.2em 0 0.2em 1.5em;
		margin: 1.8em 0;
		font-family: var(--font-display);
		font-style: italic;
		font-size: 1.2em;
		color: var(--ink);
	}
	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.3em;
	}
	.prose :global(li) {
		margin-bottom: 0.5em;
	}
	.prose :global(p:first-of-type)::first-letter {
		float: left;
		font-family: var(--font-display);
		font-size: 4em;
		line-height: 0.9;
		padding: 0.08em 0.12em 0 0;
		color: var(--accent);
		font-weight: 400;
	}
	.nav {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 2em;
		font-family: var(--font-mono);
		font-size: 0.82em;
		color: var(--slate);
		margin-top: 1em;
		flex-wrap: wrap;
	}
	.next-wrap {
		display: flex;
		flex-direction: column;
		gap: 0.6em;
		text-align: right;
		max-width: 60%;
	}
	.nav-item a {
		color: var(--accent);
		text-decoration: none;
		margin-left: 0.3em;
	}
	.nav-item a:hover {
		color: var(--blue-700);
	}
	@media (max-width: 720px) {
		.article h1 {
			font-size: 2.4em;
		}
		.a-lead {
			font-size: 1.1em;
		}
		.next-wrap {
			max-width: 100%;
			text-align: left;
		}
	}
</style>
