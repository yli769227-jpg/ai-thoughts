---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writing — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-hero {
				text-align: center;
				padding: 5em 2em 2em;
				position: relative;
			}
			.page-hero h1 {
				font-family: var(--font-display);
				font-size: 3em;
				font-weight: 400;
				color: var(--text-primary);
				margin: 0 0 0.2em;
			}
			.page-hero .count {
				font-size: 0.85em;
				color: var(--slate);
			}

			main { width: 760px; }

			.posts {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1.2em;
			}

			.card {
				background: var(--white);
				border: 1px solid var(--silver);
				border-radius: var(--radius-md);
				padding: 1.8em 2em;
				transition: all var(--transition);
				position: relative;
				overflow: hidden;
			}
			.card::before {
				content: '';
				position: absolute;
				top: 0; left: 0;
				width: 3px; height: 100%;
				background: var(--accent);
				opacity: 0;
				transition: opacity var(--transition);
			}
			.card:hover {
				border-color: var(--blue-300);
				box-shadow: var(--shadow-hover);
				transform: translateY(-2px);
			}
			.card:hover::before { opacity: 1; }

			.card a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.card-title {
				font-family: var(--font-display);
				font-size: 1.4em;
				font-weight: 400;
				color: var(--text-primary);
				margin: 0 0 0.4em;
				line-height: 1.3;
				transition: color var(--transition);
			}
			.card:hover .card-title { color: var(--accent); }

			.card-desc {
				color: var(--text-body);
				font-size: 0.92em;
				line-height: 1.65;
				margin: 0 0 1em;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.card-meta {
				font-size: 0.78em;
				color: var(--slate);
				font-variant-numeric: tabular-nums;
			}

			@media (max-width: 720px) {
				.page-hero h1 { font-size: 2.2em; }
				.card { padding: 1.3em 1.5em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="page-hero">
			<h1>Writing</h1>
			<p class="count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</p>
		</div>
		<main>
			<ul class="posts">
				{posts.map((post) => (
					<li class="card">
						<a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`}>
							<h3 class="card-title">{post.data.title}</h3>
							{post.data.description && <p class="card-desc">{post.data.description}</p>}
							<span class="card-meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
