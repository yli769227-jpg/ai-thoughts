---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.page-header {
				text-align: center;
				padding: 3em 1em 1em;
			}
			.page-header h1 {
				font-size: 2em;
				color: var(--accent);
			}
			.page-header p {
				color: var(--text-muted);
				font-size: 0.95em;
			}
			main { width: 760px; }
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.post-card {
				padding: 1.5em;
				border: 1px solid var(--border);
				border-radius: 10px;
				background: var(--bg-card);
				transition: all 0.3s ease;
			}
			.post-card:hover {
				border-color: rgba(100, 255, 218, 0.3);
				box-shadow: 0 0 30px rgba(100, 255, 218, 0.05);
				transform: translateY(-2px);
			}
			.post-card a {
				text-decoration: none;
				color: inherit;
			}
			.post-card h3 {
				margin: 0 0 0.3em;
				font-size: 1.3em;
				color: var(--text-primary);
				transition: color 0.3s;
			}
			.post-card:hover h3 { color: var(--accent); }
			.post-card .description {
				color: var(--text-secondary);
				font-size: 0.9em;
				margin: 0 0 0.8em;
				line-height: 1.6;
			}
			.post-card .meta {
				color: var(--text-muted);
				font-size: 0.8em;
			}
			@media (max-width: 720px) {
				.post-card { padding: 1em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="page-header">
			<h1>全部文章</h1>
			<p>共 {posts.length} 篇</p>
		</div>
		<main>
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-card">
						<a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
							<h3>{post.data.title}</h3>
							{post.data.description && <p class="description">{post.data.description}</p>}
							<span class="meta"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>
