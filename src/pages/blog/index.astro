---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const total = posts.length;
---
<BaseLayout title="Writing">
	<main class="container">
		<section class="hero">
			<div class="kicker">
				<span class="bar"></span>
				<span>INDEX · ALL ENTRIES</span>
			</div>
			<h1 data-reveal-words>Writing.</h1>
			<p class="lead">{total} 篇。按时间倒序。</p>
		</section>
		<PostList />
	</main>
</BaseLayout>

<style>
	.hero {
		padding: 3em 0 1em;
	}
	.kicker {
		font-family: var(--font-mono);
		font-size: 0.78em;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.5em;
		display: flex;
		gap: 0.8em;
		align-items: center;
	}
	.kicker .bar {
		display: inline-block;
		width: 28px;
		height: 1px;
		background: var(--accent);
	}
	.hero h1 {
		font-family: var(--font-display);
		font-size: 4.8em;
		line-height: 1;
		letter-spacing: -0.02em;
		margin: 0 0 0.4em;
		color: var(--ink);
		font-weight: 400;
	}
	.lead {
		font-family: var(--font-display);
		font-size: 1.4em;
		font-style: italic;
		color: var(--ink);
		margin: 0 0 2em;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 2.8em;
		}
	}
</style>
