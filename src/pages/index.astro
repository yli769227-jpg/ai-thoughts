---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts[0];
const total = posts.length;
const latestDate = latest?.data.pubDate.toISOString().slice(0, 10) ?? '';
---
<BaseLayout>
	<main class="container">
		<section class="hero">
			<div class="kicker">
				<span class="bar"></span>
				<span>LOG · APR 2026 · {total} ENTRIES</span>
			</div>
			<h1 data-reveal-words>Personal reflections<br />on <em>artificial intelligence</em>.</h1>
			<p class="lead">模型每三个月换一代。对话会失效,prompt 会过时 — 写下来的判断力不会。</p>
			<div class="meta">
				<span><b>author</b> · yao li</span>
				<span><b>stack</b> · astro · markdown</span>
				<span><b>latest</b> · {latestDate}</span>
				<span><b>status</b> · <span class="live">● writing</span></span>
			</div>
		</section>

		<div class="list-head">
			<h3>Entries</h3>
			<span class="count">[latest {Math.min(4, total)} of {total}]</span>
		</div>
		<PostList limit={4} />

		<div class="more">
			<a href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/blog/'}>view all {total} entries →</a>
		</div>
	</main>
</BaseLayout>

<style>
	.hero {
		padding: 3.5em 0 2em;
		position: relative;
	}
	.kicker {
		font-family: var(--font-mono);
		font-size: 0.78em;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: var(--accent);
		margin-bottom: 1.5em;
		display: flex;
		gap: 0.8em;
		align-items: center;
	}
	.kicker .bar {
		display: inline-block;
		width: 28px;
		height: 1px;
		background: var(--accent);
	}
	.hero h1 {
		font-family: var(--font-display);
		font-size: 5.2em;
		line-height: 1;
		letter-spacing: -0.02em;
		margin: 0 0 0.4em;
		color: var(--ink);
		font-weight: 400;
	}
	.hero h1 :global(em) {
		font-style: italic;
		color: var(--accent);
	}
	.lead {
		font-family: var(--font-display);
		font-size: 1.55em;
		font-style: italic;
		color: var(--ink);
		line-height: 1.45;
		max-width: 640px;
		margin: 0;
	}
	.meta {
		margin-top: 3em;
		display: flex;
		gap: 2.5em;
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--slate);
		flex-wrap: wrap;
	}
	.meta b {
		color: var(--ink);
		font-weight: 500;
	}
	.live {
		color: #2e9d68;
	}
	.list-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin: 4em 0 1em;
		padding-bottom: 0.6em;
		border-bottom: 1px solid var(--silver);
	}
	.list-head h3 {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: 1.7em;
		color: var(--ink);
	}
	.list-head .count {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--slate);
		letter-spacing: 0.1em;
	}
	.more {
		margin-top: 2em;
		font-family: var(--font-mono);
		font-size: 0.85em;
	}
	.more a {
		color: var(--accent);
		text-decoration: none;
	}
	.more a:hover {
		color: var(--blue-700);
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 3em;
		}
		.lead {
			font-size: 1.2em;
		}
		.meta {
			gap: 1.2em;
		}
	}
</style>
