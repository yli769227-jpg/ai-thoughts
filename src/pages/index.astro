---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/* --- Hero --- */
			.hero {
				position: relative;
				padding: 8em 2em 6em;
				overflow: hidden;
				background: var(--white);
			}

			/* Fluid organic blobs */
			.hero-blob {
				position: absolute;
				border-radius: 50%;
				filter: blur(80px);
				opacity: 0.35;
				animation: float 18s ease-in-out infinite;
			}
			.hero-blob--1 {
				width: 500px; height: 500px;
				background: var(--blue-200);
				top: -15%; right: -8%;
				animation-delay: 0s;
			}
			.hero-blob--2 {
				width: 350px; height: 350px;
				background: var(--blue-100);
				bottom: -10%; left: 5%;
				animation-delay: -6s;
				animation-duration: 22s;
			}
			.hero-blob--3 {
				width: 200px; height: 200px;
				background: var(--blue-300);
				top: 30%; left: 35%;
				opacity: 0.15;
				animation-delay: -12s;
				animation-duration: 25s;
			}

			@keyframes float {
				0%, 100% { transform: translate(0, 0) scale(1); }
				25% { transform: translate(15px, -20px) scale(1.03); }
				50% { transform: translate(-10px, 15px) scale(0.97); }
				75% { transform: translate(20px, 10px) scale(1.02); }
			}

			.hero-content {
				position: relative;
				z-index: 1;
				max-width: 680px;
				margin: 0 auto;
			}

			.hero-tag {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-body);
				font-size: 0.78em;
				font-weight: 500;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: var(--accent);
				margin-bottom: 1.5em;
				opacity: 0;
				animation: fadeUp 0.8s ease forwards 0.2s;
			}
			.hero-tag::before {
				content: '';
				display: block;
				width: 24px; height: 1.5px;
				background: var(--accent);
			}

			.hero h1 {
				font-family: var(--font-display);
				font-size: 4.5em;
				font-weight: 400;
				line-height: 1.08;
				color: var(--text-primary);
				margin: 0 0 0.35em;
				letter-spacing: -0.02em;
				opacity: 0;
				animation: fadeUp 0.8s ease forwards 0.35s;
			}
			.hero h1 em {
				font-style: italic;
				color: var(--accent);
			}

			.hero-desc {
				font-size: 1.15em;
				color: var(--text-body);
				line-height: 1.7;
				max-width: 480px;
				margin-bottom: 2.5em;
				opacity: 0;
				animation: fadeUp 0.8s ease forwards 0.5s;
			}

			.hero-cta {
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
				font-family: var(--font-body);
				font-size: 0.88em;
				font-weight: 500;
				letter-spacing: 0.04em;
				color: var(--accent);
				padding: 0.65em 1.6em;
				border: 1.5px solid var(--blue-300);
				border-radius: 100px;
				transition: all var(--transition);
				opacity: 0;
				animation: fadeUp 0.8s ease forwards 0.65s;
			}
			.hero-cta:hover {
				background: var(--accent);
				border-color: var(--accent);
				color: var(--white);
				box-shadow: 0 4px 20px rgba(66, 114, 196, 0.25);
			}
			.hero-cta span {
				transition: transform var(--transition);
			}
			.hero-cta:hover span {
				transform: translateX(3px);
			}

			@keyframes fadeUp {
				from { opacity: 0; transform: translateY(16px); }
				to { opacity: 1; transform: translateY(0); }
			}

			/* --- Recent Posts --- */
			.recent {
				max-width: 720px;
				margin: 0 auto;
				padding: 3em 2em 4em;
			}

			.section-label {
				font-family: var(--font-body);
				font-size: 0.75em;
				font-weight: 500;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--slate);
				margin-bottom: 2.5em;
				display: flex;
				align-items: center;
				gap: 1em;
			}
			.section-label::after {
				content: '';
				flex: 1;
				height: 1px;
				background: var(--silver);
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.post-item {
				border-bottom: 1px solid rgba(228, 232, 241, 0.5);
			}
			.post-item:last-child { border-bottom: none; }

			.post-link {
				display: grid;
				grid-template-columns: 1fr auto;
				align-items: baseline;
				gap: 2em;
				padding: 1.3em 0;
				color: var(--text-primary);
				transition: all var(--transition);
				text-decoration: none;
			}
			.post-link:hover {
				color: var(--accent);
			}
			.post-link:hover .post-title {
				color: var(--accent);
			}

			.post-title {
				font-family: var(--font-display);
				font-size: 1.25em;
				font-weight: 400;
				color: var(--text-primary);
				transition: color var(--transition);
				line-height: 1.3;
			}

			.post-date {
				font-size: 0.82em;
				color: var(--slate);
				white-space: nowrap;
				font-variant-numeric: tabular-nums;
			}

			@media (max-width: 720px) {
				.hero { padding: 5em 1.5em 4em; }
				.hero h1 { font-size: 2.8em; }
				.hero-desc { font-size: 1em; }
				.recent { padding: 2em 1.2em 3em; }
				.post-link {
					grid-template-columns: 1fr;
					gap: 0.3em;
					padding: 1em 0;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<section class="hero">
			<div class="hero-blob hero-blob--1"></div>
			<div class="hero-blob hero-blob--2"></div>
			<div class="hero-blob hero-blob--3"></div>
			<div class="hero-content">
				<div class="hero-tag">Personal Reflections</div>
				<h1>Thinking<br/>about <em>AI</em></h1>
				<p class="hero-desc">
					Observations, reflections, and ideas on artificial intelligence
					— written from a personal point of view, not a textbook.
				</p>
				<a class="hero-cta" href={`${import.meta.env.BASE_URL}blog`}>
					Read all posts <span>&rarr;</span>
				</a>
			</div>
		</section>

		<section class="recent">
			<div class="section-label">Recent</div>
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-item">
						<a class="post-link" href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>
							<span class="post-title">{post.data.title}</span>
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</section>

		<Footer />
	</body>
</html>
