---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---
<footer class="site-footer">
	<div class="wrap">
		<span>© {year} ai-thought · built with astro · <span class="live">●</span> live</span>
		<span>
			<a href={base + '/rss.xml'}>rss.xml</a>
			<span class="sep">·</span>
			<a href="https://github.com/yli769227-jpg/ai-thoughts" target="_blank" rel="noopener">github</a>
		</span>
	</div>
</footer>

<style>
	.site-footer {
		margin-top: 4em;
		padding: 2em 0;
		border-top: 1px solid var(--silver);
		color: var(--slate);
		font-family: var(--font-mono);
		font-size: 0.78em;
	}
	.wrap {
		width: 960px;
		max-width: calc(100% - 3em);
		margin: auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.sep {
		margin: 0 0.4em;
	}
	a {
		color: var(--slate);
		text-decoration: none;
		transition: color var(--transition);
	}
	a:hover {
		color: var(--accent);
	}
	.live {
		color: var(--accent);
	}
</style>
