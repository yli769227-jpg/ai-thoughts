---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-line"></div>
		<div class="footer-content">
			<span class="footer-logo"><em>ai</em>—thought</span>
			<span class="footer-copy">&copy; {today.getFullYear()} Li Yao</span>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 0 2em 4em;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 860px;
		margin: 0 auto;
	}
	.footer-line {
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--silver), transparent);
		margin-bottom: 2em;
	}
	.footer-content {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.footer-logo {
		font-family: var(--font-body);
		font-size: 0.85em;
		font-weight: 500;
		color: var(--slate);
		letter-spacing: 0.02em;
	}
	.footer-logo em {
		font-family: var(--font-display);
		font-style: italic;
		color: var(--accent);
	}
	.footer-copy {
		font-size: 0.8em;
		color: var(--slate);
	}
	@media (max-width: 720px) {
		footer { padding: 0 1.2em 3em; }
	}
</style>
