---
// Flowing blue blob background + faint grid + cursor halo.
// All client-side and decorative.
---
<div class="bg-fx" aria-hidden="true">
	<svg viewBox="0 0 1600 1000" preserveAspectRatio="xMidYMid slice">
		<defs>
			<filter id="goo">
				<feGaussianBlur stdDeviation="60" in="SourceGraphic" />
			</filter>
			<radialGradient id="g1" cx="50%" cy="50%" r="50%">
				<stop offset="0%" stop-color="#9fbae8" stop-opacity=".9" />
				<stop offset="100%" stop-color="#9fbae8" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="g2" cx="50%" cy="50%" r="50%">
				<stop offset="0%" stop-color="#2948ff" stop-opacity=".5" />
				<stop offset="100%" stop-color="#2948ff" stop-opacity="0" />
			</radialGradient>
			<radialGradient id="g3" cx="50%" cy="50%" r="50%">
				<stop offset="0%" stop-color="#c7d9f7" stop-opacity="1" />
				<stop offset="100%" stop-color="#c7d9f7" stop-opacity="0" />
			</radialGradient>
		</defs>
		<g filter="url(#goo)">
			<circle class="blob" cx="280" cy="220" r="260" fill="url(#g1)" />
			<circle class="blob b2" cx="1320" cy="180" r="240" fill="url(#g2)" />
			<circle class="blob b3" cx="900" cy="700" r="300" fill="url(#g3)" />
			<circle class="blob b2" cx="180" cy="820" r="220" fill="url(#g1)" />
		</g>
	</svg>
</div>
<div class="bg-grid" aria-hidden="true"></div>
<div class="bg-halo" aria-hidden="true" id="bg-halo"></div>
<div class="scroll-progress" id="scroll-progress"></div>

<script is:inline>
	(function () {
		// scroll progress
		const prog = document.getElementById('scroll-progress');
		function onScroll() {
			const max = document.documentElement.scrollHeight - innerHeight;
			if (prog) prog.style.width = max > 0 ? (scrollY / max * 100) + '%' : '0';
		}
		addEventListener('scroll', onScroll, { passive: true });
		onScroll();

		// cursor halo
		const halo = document.getElementById('bg-halo');
		let mx = -9999, my = -9999, hx = -9999, hy = -9999;
		addEventListener('pointermove', (e) => { mx = e.clientX - 260; my = e.clientY - 260; });
		(function tick() {
			hx += (mx - hx) * 0.12;
			hy += (my - hy) * 0.12;
			if (halo) halo.style.transform = `translate(${hx}px, ${hy}px)`;
			requestAnimationFrame(tick);
		})();

		// burst particles on post-card clicks
		document.addEventListener('click', (e) => {
			const card = e.target.closest && e.target.closest('[data-burst]');
			if (!card) return;
			const cx = e.clientX, cy = e.clientY;
			const N = 14;
			const colors = ['#2948ff', '#6b93d6', '#c7d9f7'];
			for (let i = 0; i < N; i++) {
				const b = document.createElement('div');
				b.className = 'burst';
				const size = 6 + Math.random() * 10;
				b.style.width = b.style.height = size + 'px';
				b.style.left = (cx - size / 2) + 'px';
				b.style.top = (cy - size / 2) + 'px';
				b.style.background = colors[Math.floor(Math.random() * colors.length)];
				document.body.appendChild(b);
				const ang = (i / N) * Math.PI * 2 + Math.random() * 0.6;
				const dist = 60 + Math.random() * 120;
				const dx = Math.cos(ang) * dist;
				const dy = Math.sin(ang) * dist - 20;
				b.animate(
					[
						{ transform: 'translate(0,0) scale(1)', opacity: 0.9 },
						{ transform: `translate(${dx}px, ${dy}px) scale(.2)`, opacity: 0 },
					],
					{ duration: 700 + Math.random() * 300, easing: 'cubic-bezier(.18,.9,.32,1)' }
				).onfinish = () => b.remove();
			}
			const flash = document.createElement('div');
			flash.style.cssText = 'position:absolute;inset:0;background:rgba(41,72,255,.08);pointer-events:none;border-radius:8px;animation:flashout .5s ease-out forwards';
			card.style.position = 'relative';
			card.appendChild(flash);
			setTimeout(() => flash.remove(), 500);
		});

		// word-by-word reveal for [data-reveal-words]
		document.querySelectorAll('[data-reveal-words]').forEach((el) => {
			const html = el.innerHTML;
			el.innerHTML = html.split(/(<[^>]+>|\s+)/).map((t) => {
				if (!t || /^<|^\s+$/.test(t)) return t;
				return t.split(' ').map((w) => (w ? `<span class="reveal-word">${w}</span>` : '')).join(' ');
			}).join('');
			const words = el.querySelectorAll('.reveal-word');
			words.forEach((w, i) => setTimeout(() => w.classList.add('in'), 80 + i * 50));
		});

		// line reveal for prose
		const obs = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						obs.unobserve(e.target);
					}
				});
			},
			{ threshold: 0.15 }
		);
		document.querySelectorAll('[data-reveal-children] > *').forEach((n) => {
			n.classList.add('reveal-line');
			obs.observe(n);
		});
	})();
</script>
