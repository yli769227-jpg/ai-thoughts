---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="logo" href={`${import.meta.env.BASE_URL}`}>
			<span class="logo-icon">&#x2732;</span>
			<span class="logo-text">{SITE_TITLE}</span>
		</a>
		<div class="nav-links">
			<HeaderLink href={`${import.meta.env.BASE_URL}`}>首页</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}blog`}>文章</HeaderLink>
			<HeaderLink href={`${import.meta.env.BASE_URL}about`}>关于</HeaderLink>
			<a class="github-link" href="https://github.com/yli769227-jpg" target="_blank" aria-label="GitHub">
				<svg viewBox="0 0 16 16" width="20" height="20"><path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: rgba(10, 14, 23, 0.85);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.8em 1.5em;
	}
	.logo {
		display: flex;
		align-items: center;
		gap: 0.5em;
		text-decoration: none;
		color: var(--text-primary);
		font-weight: 700;
		font-size: 1.1em;
	}
	.logo:hover { color: var(--accent); }
	.logo-icon {
		font-size: 1.4em;
		color: var(--accent);
		filter: drop-shadow(0 0 6px rgba(100, 255, 218, 0.4));
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	.github-link {
		color: var(--text-secondary);
		display: flex;
		align-items: center;
		margin-left: 0.5em;
	}
	.github-link:hover { color: var(--accent); }
</style>
