---
const { pathname } = Astro.url;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const is = (href) => {
	const target = base + href;
	if (href === '/') return pathname === base + '/' || pathname === base || pathname === '/';
	return pathname === target || pathname.startsWith(target + '/');
};
---
<header class="site-header">
	<div class="wrap">
		<a href={base + '/'} class="brand">
			<span class="dot"></span>ai<em>·thought</em><span class="caret"></span>
		</a>
		<nav>
			<a href={base + '/'} class:list={[{ active: is('/') && !is('/blog') && !is('/about') }]}>~/home</a>
			<a href={base + '/blog/'} class:list={[{ active: is('/blog') }]}>writing</a>
			<a href={base + '/about/'} class:list={[{ active: is('/about') }]}>about</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: blur(14px) saturate(140%);
		-webkit-backdrop-filter: blur(14px) saturate(140%);
		background: rgba(255, 255, 255, 0.72);
		border-bottom: 1px solid rgba(14, 28, 56, 0.06);
	}
	.wrap {
		width: 960px;
		max-width: calc(100% - 3em);
		margin: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.1em 0;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 0.55em;
		color: var(--ink);
		text-decoration: none;
		font-family: var(--font-display);
		font-size: 1.45em;
		letter-spacing: -0.01em;
	}
	.brand .dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: var(--accent);
		box-shadow: 0 0 0 4px rgba(41, 72, 255, 0.15);
		animation: pulse 2.2s ease-in-out infinite;
	}
	.brand em {
		font-style: italic;
		color: var(--accent);
	}
	nav {
		display: flex;
		gap: 1.4em;
		font-family: var(--font-mono);
		font-size: 0.82em;
	}
	nav a {
		position: relative;
		color: var(--slate);
		text-decoration: none;
		padding: 0.4em 0;
		transition: color var(--transition);
	}
	nav a::after {
		content: '';
		position: absolute;
		left: 0;
		right: 100%;
		bottom: 0;
		height: 2px;
		background: var(--accent);
		transition: right 0.35s cubic-bezier(0.23, 1, 0.32, 1);
	}
	nav a:hover,
	nav a.active {
		color: var(--ink);
	}
	nav a:hover::after,
	nav a.active::after {
		right: 0;
	}
	@media (max-width: 720px) {
		nav {
			gap: 0.9em;
		}
	}
</style>
